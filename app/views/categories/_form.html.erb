<%= form_with model: category, class: "space-y-6" do |f| %>
  <% if category.errors.any? %>
    <div class="p-4 bg-[#fef2f2] border border-[#fecaca] rounded-card text-red-700 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-navy tracking-[0.07px] mb-1.5" %>
    <%= f.text_field :name,
          class: "w-full border border-border rounded-lg px-3 py-2 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-cairn/20 focus:border-cairn transition-colors",
          placeholder: "Category name" %>
    <p class="mt-1.5 text-xs text-text-weak">Slug is auto-generated from the name.</p>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit category.new_record? ? "Create Category" : "Save Changes",
          class: "px-6 py-2 bg-cairn hover:bg-cairn-hover text-white rounded-btn text-sm font-medium cursor-pointer transition-colors" %>
    <%= link_to "Cancel", categories_path,
          class: "px-4 py-2 border border-border text-navy hover:bg-surface rounded-btn text-sm transition-colors" %>
  </div>
<% end %>
