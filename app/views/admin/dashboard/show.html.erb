<% content_for :title, "Dashboard" %>

<div class="mb-10">
  <h1 class="text-2xl font-semibold text-navy tracking-[-0.2px]">Dashboard</h1>
  <p class="text-sm text-text-weak mt-1">Overview of Cairn CMS content and users</p>
</div>

<h2 class="text-xs font-semibold text-navy/50 uppercase tracking-[0.07px] mb-3">Users</h2>
<div class="grid grid-cols-3 gap-4 mb-10">
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Admin</p>
    <p class="text-3xl font-semibold text-navy"><%= @user_counts["admin"] || 0 %></p>
  </div>
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Editor</p>
    <p class="text-3xl font-semibold text-navy"><%= @user_counts["editor"] || 0 %></p>
  </div>
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Author</p>
    <p class="text-3xl font-semibold text-navy"><%= @user_counts["author"] || 0 %></p>
  </div>
</div>

<h2 class="text-xs font-semibold text-navy/50 uppercase tracking-[0.07px] mb-3">Content</h2>
<div class="grid grid-cols-4 gap-4 mb-10">
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Draft</p>
    <p class="text-3xl font-semibold text-navy"><%= @post_counts["draft"] || 0 %></p>
  </div>
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">In Review</p>
    <p class="text-3xl font-semibold text-navy"><%= @post_counts["in_review"] || 0 %></p>
  </div>
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Published</p>
    <p class="text-3xl font-semibold text-navy"><%= @post_counts["published"] || 0 %></p>
  </div>
  <div class="bg-white border border-border rounded-card shadow-card p-5">
    <p class="text-xs text-text-weak font-medium uppercase tracking-[0.07px] mb-2">Archived</p>
    <p class="text-3xl font-semibold text-navy"><%= @post_counts["archived"] || 0 %></p>
  </div>
</div>

<h2 class="text-xs font-semibold text-navy/50 uppercase tracking-[0.07px] mb-3">Recent Posts</h2>
<% if @recent_posts.empty? %>
  <div class="text-center py-16 text-text-weak text-sm">
    No posts yet.
  </div>
<% else %>
  <div class="border border-border rounded-card overflow-hidden shadow-card">
    <table class="min-w-full divide-y divide-border text-sm">
      <thead class="bg-surface">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Title</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Status</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Author</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border bg-white">
        <% @recent_posts.each do |post| %>
          <tr class="hover:bg-surface transition-colors">
            <td class="px-5 py-3.5 font-medium">
              <%= link_to post.title, post_path(post),
                    class: "text-navy hover:text-cairn transition-colors" %>
            </td>
            <td class="px-5 py-3.5">
              <span class="<%= status_badge_classes(post.status) %> px-2.5 py-1 rounded-full text-xs font-medium">
                <%= post.status.humanize %>
              </span>
            </td>
            <td class="px-5 py-3.5 text-text-weak"><%= post.author.email %></td>
            <td class="px-5 py-3.5 text-text-weak"><%= post.created_at.strftime("%b %-d, %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
