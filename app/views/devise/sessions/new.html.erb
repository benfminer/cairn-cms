<% content_for :title, "Sign In" %>

<div class="min-h-[calc(100vh-3.5rem)] flex items-center justify-center -mt-10 -mx-6 px-6 py-12">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-navy tracking-[-0.2px]">Cairn</h1>
      <p class="text-sm text-text-weak mt-1">Sign in to your account</p>
    </div>

    <div class="bg-white border border-border rounded-card shadow-card p-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-navy tracking-[0.07px] mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full border border-border rounded-lg px-3 py-2 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-cairn/20 focus:border-cairn transition-colors" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-navy tracking-[0.07px] mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full border border-border rounded-lg px-3 py-2 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-cairn/20 focus:border-cairn transition-colors" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded border-border text-cairn" %>
            <%= f.label :remember_me, class: "text-sm text-text-weak" %>
          </div>
        <% end %>

        <div class="pt-1">
          <%= f.submit "Sign in",
                class: "w-full py-2.5 bg-cairn hover:bg-cairn-hover text-white rounded-btn text-sm font-medium cursor-pointer transition-colors" %>
        </div>
      <% end %>
    </div>

    <div class="mt-5 text-center text-sm space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
