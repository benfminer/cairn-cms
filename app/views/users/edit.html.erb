<% content_for :title, "Edit Profile" %>

<div class="max-w-lg mx-auto mt-10 p-6 bg-white rounded shadow">
  <h1 class="text-2xl font-bold mb-4">Edit Profile</h1>

  <%= form_with model: @user, url: user_path(@user), method: :patch do |f| %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded">
        <ul class="list-disc list-inside text-red-700 text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
            autocomplete: "email" %>
    </div>

    <div class="flex gap-4">
      <%= f.submit "Save Changes",
            class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", user_path(@user),
            class: "px-4 py-2 border border-gray-300 rounded hover:bg-gray-50" %>
    </div>
  <% end %>
</div>
