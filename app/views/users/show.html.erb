<% content_for :title, "#{@user.email} — Profile" %>

<div class="max-w-lg mx-auto bg-white border border-border rounded-card shadow-card p-8">
  <h1 class="text-xl font-semibold text-navy tracking-[-0.1px] mb-6">Profile</h1>

  <dl class="space-y-5">
    <div>
      <dt class="text-xs font-medium text-text-weak uppercase tracking-[0.07px] mb-1">Email</dt>
      <dd class="text-navy text-sm"><%= @user.email %></dd>
    </div>
    <div>
      <dt class="text-xs font-medium text-text-weak uppercase tracking-[0.07px] mb-1">Role</dt>
      <dd class="text-navy text-sm capitalize"><%= @user.role %></dd>
    </div>
  </dl>

  <% if policy(@user).update? %>
    <div class="mt-8 pt-6 border-t border-border">
      <%= link_to "Edit Profile", edit_user_path(@user),
            class: "px-4 py-2 bg-cairn hover:bg-cairn-hover text-white rounded-btn text-sm font-medium transition-colors inline-block" %>
    </div>
  <% end %>
</div>
