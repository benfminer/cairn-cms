<% content_for :title, "Tags" %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-semibold text-navy tracking-[-0.2px]">Tags</h1>
  <% if policy(Tag.new).create? %>
    <%= link_to "New Tag", new_tag_path,
          class: "px-4 py-2 bg-cairn hover:bg-cairn-hover text-white rounded-btn text-sm font-medium transition-colors" %>
  <% end %>
</div>

<% if @tags.empty? %>
  <div class="text-center py-16 text-text-weak text-sm">No tags yet.</div>
<% else %>
  <div class="border border-border rounded-card overflow-hidden shadow-card">
    <table class="min-w-full divide-y divide-border text-sm">
      <thead class="bg-surface">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Name</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Slug</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Posts</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border bg-white">
        <% @tags.each do |tag| %>
          <tr class="hover:bg-surface transition-colors">
            <td class="px-5 py-3.5 font-medium text-navy"><%= tag.name %></td>
            <td class="px-5 py-3.5 text-text-weak font-mono text-xs"><%= tag.slug %></td>
            <td class="px-5 py-3.5 text-text-weak"><%= tag.posts.count %></td>
            <td class="px-5 py-3.5 text-right space-x-3">
              <% if policy(tag).update? %>
                <%= link_to "Edit", edit_tag_path(tag),
                      class: "text-cairn hover:underline text-xs font-medium" %>
              <% end %>
              <% if policy(tag).destroy? %>
                <%= button_to "Delete", tag_path(tag), method: :delete,
                      class: "text-red-500 hover:underline text-xs font-medium bg-transparent border-0 p-0 cursor-pointer",
                      data: { turbo_confirm: "Delete this tag? Posts will be untagged." } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
