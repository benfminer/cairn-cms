<% content_for :title, "Posts" %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-semibold text-navy tracking-[-0.2px]">Posts</h1>
  <%= link_to "New Post", new_post_path,
        class: "px-4 py-2 bg-cairn hover:bg-cairn-hover text-white rounded-btn text-sm font-medium transition-colors" %>
</div>

<% if @categories.any? %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "All", posts_path,
          class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@selected_category.blank? ? 'bg-cairn text-white border-cairn' : 'border-border text-navy hover:bg-surface'}" %>
    <% @categories.each do |cat| %>
      <%= link_to cat.name, posts_path(category_id: cat.id),
            class: "px-3 py-1 rounded-full text-xs font-medium border transition-colors #{@selected_category == cat.id.to_s ? 'bg-cairn text-white border-cairn' : 'border-border text-navy hover:bg-surface'}" %>
    <% end %>
  </div>
<% end %>

<% if @posts.empty? %>
  <div class="text-center py-16 text-text-weak text-sm">
    No posts yet.
  </div>
<% else %>
  <div class="border border-border rounded-card overflow-hidden shadow-card">
    <table class="min-w-full divide-y divide-border text-sm">
      <thead class="bg-surface">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Title</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Status</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Author</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-navy/60 uppercase tracking-[0.07px]">Created</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border bg-white">
        <% @posts.each do |post| %>
          <tr class="hover:bg-surface transition-colors">
            <td class="px-5 py-3.5 font-medium">
              <%= link_to post.title, post_path(post),
                    class: "text-navy hover:text-cairn transition-colors" %>
            </td>
            <td class="px-5 py-3.5">
              <span class="<%= status_badge_classes(post.status) %> px-2.5 py-1 rounded-full text-xs font-medium">
                <%= post.status.humanize %>
              </span>
            </td>
            <td class="px-5 py-3.5 text-text-weak"><%= post.author.email %></td>
            <td class="px-5 py-3.5 text-text-weak"><%= post.created_at.strftime("%b %-d, %Y") %></td>
            <td class="px-5 py-3.5 text-right space-x-3">
              <% if policy(post).update? %>
                <%= link_to "Edit", edit_post_path(post),
                      class: "text-cairn hover:underline text-xs font-medium" %>
              <% end %>
              <% if policy(post).destroy? %>
                <%= button_to "Delete", post_path(post), method: :delete,
                      class: "text-red-500 hover:underline text-xs font-medium bg-transparent border-0 p-0 cursor-pointer",
                      data: { turbo_confirm: "Delete this post?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
