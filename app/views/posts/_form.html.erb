<%= form_with model: post, class: "space-y-6" do |f| %>
  <% if post.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded">
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
          class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "Post title" %>
  </div>

  <div>
    <%= f.label :body, "Content", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.rich_text_area :body %>
  </div>

  <% unless current_user.author? %>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status,
            Post.statuses.keys.map { |s| [s.humanize, s] },
            {},
            class: "border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
  <% end %>

  <div class="flex gap-4">
    <%= f.submit post.new_record? ? "Create Post" : "Save Changes",
          class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer text-sm font-medium" %>
    <%= link_to "Cancel", post.new_record? ? posts_path : post_path(post),
          class: "px-4 py-2 border border-gray-300 rounded hover:bg-gray-50 text-sm" %>
  </div>
<% end %>
